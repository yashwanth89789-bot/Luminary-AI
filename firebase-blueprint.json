{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A collection of documents (Knowledge Base)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId"]
    },
    "Document": {
      "title": "Document",
      "description": "A single document within a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "title", "content", "ownerId"]
    },
    "Chunk": {
      "title": "Chunk",
      "description": "A chunk of a document with its vector embedding",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "documentId": { "type": "string" },
        "projectId": { "type": "string" },
        "text": { "type": "string" },
        "embedding": { "type": "array", "items": { "type": "number" } },
        "ownerId": { "type": "string" },
        "chunkIndex": { "type": "integer" }
      },
      "required": ["id", "documentId", "projectId", "text", "embedding", "ownerId"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Knowledge base projects"
    },
    "/projects/{projectId}/documents/{documentId}": {
      "schema": "Document",
      "description": "Documents within a project"
    },
    "/projects/{projectId}/chunks/{chunkId}": {
      "schema": "Chunk",
      "description": "Document chunks with embeddings for vector search"
    }
  }
}
